    </link>

    <!-- ============================= -->
    <!-- Wheels_Lump -->
    <!-- ============================= -->

    <!-- wheel_front_left_joint-->
    <joint name='wheel_front_left_joint' type='revolute'>
      <pose relative_to='base_footprint'>0 -0.17827 0.082 0 -0 0</pose>
      <parent>base_footprint</parent>
      <child>wheel_front_left_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.005</damping>
          <friction>0.005</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

     <!-- wheel_front_left_link-->
    <link name='wheel_front_left_link'>
      <pose relative_to='wheel_front_left_joint'>0 0 0 0 -0 0</pose>

      <inertial>
        <pose>0 0 0 0 -0 0</pose>
        <mass>7.90271</mass>
        <inertia>
          <ixx>0.01506</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.01506</iyy>
          <iyz>0</iyz>
