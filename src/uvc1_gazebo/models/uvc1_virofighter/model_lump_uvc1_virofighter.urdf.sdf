<?xml version="1.0" ?>
<sdf version='1.7'>
  <model name='uvc1_virofighter'>

    <!-- ============================= -->
    <!-- Base_Footprint_Fixed_Joint_Lump -->
    <!-- ============================= -->
    <link name='base_footprint'>

      <inertial>
        <pose>-0.035763 1.6e-05 0.067205 0 -0 0</pose>
        <mass>11.232</mass>
        <inertia>
          <ixx>13.8027</ixx>
          <ixy>6.05581e-05</ixy>
          <ixz>0.180382</ixz>
          <iyy>14.1077</iyy>
          <iyz>-4.09128e-05</iyz>
          <izz>0.485685</izz>
        </inertia>
      </inertial>

      <!-- base_footprint_fixed_joint_lump__base_collision_collision -->
      <!-- base_footprint_fixed_joint_lump__base_visual_visual -->
      <collision name='base_collision'>
        <pose>-0.25 0 1 0 -0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://uvc1_common/meshes/bases/Cube.019.dae</uri>
          </mesh>
        </geometry>
      </collision>

      <visual name='base_visual'>
        <pose>-0.25 0 0.049 0 -0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://uvc1_common/meshes/bases/virofighter_base.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <!--base_footprint_fixed_joint_lump__camera_d455_collision_collision_2 -->
      <!--base_footprint_fixed_joint_lump__d455_visual_visual_2 -->
      <collision name='camera_d455_collision_2'>
        <pose>-0.52457 0 0.42892 -3.14159 1.5708 0</pose>
        <geometry>
          <box>
            <size>0.124 0.029 0.025</size>
          </box>
        </geometry>
      </collision>

      <visual name='d455_visual_visual_2'>
        <pose>-0.52457 0 0.42892 0 0 -3.14156</pose>
        <geometry>
          <box>
            <size>0.124 0.029 0.025</size>
          </box>
        </geometry>
      </visual>

      <!--camera_d455_rgb sensor gazebo plugin-->
      <sensor name='d455_rgb' type='camera'>
        <always_on>1</always_on>
        <visualize>1</visualize>
        <update_rate>30</update_rate>
        <pose>-0.52457 0 0.42892 0 -0 0</pose>

        <camera>
          <horizontal_fov>1.5</horizontal_fov>
          <image><width>1280</width><height>800</height><format>R8G8B8</format></image>
          <clip><near>0.05</near><far>20</far></clip>
        </camera>

        <plugin name='d455_rgb_camera_controller' filename='libgazebo_ros_camera.so'>
          <ros><namespace>/d455/rgb</namespace></ros>
          <frame_name>camera_d455_color_optical_frame</frame_name>
          <image_topic_name>/d455/color/image_raw</image_topic_name>
          <camera_info_topic_name>/d455/color/camera_info</camera_info_topic_name>
        </plugin>
      </sensor>

      
      <!--camera_d455_depth sensor gazebo plugin-->
      <sensor name='d455_depth' type='camera'>
        <always_on>1</always_on>
        <visualize>1</visualize>
        <update_rate>30</update_rate>
        <pose>-0.52457 0 0.42892 0 -0 0</pose>

        <camera>
          <horizontal_fov>1.52</horizontal_fov>
          <depth_camera><clip><near>0.6</near><far>6</far></clip></depth_camera>
          <image><width>1280</width><height>720</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>100</far></clip>
        </camera>

        <plugin name='d455_depth_camera_controller' filename='libgazebo_ros_depth_camera.so'>
          <ros><namespace>/d455/depth</namespace></ros>
          <frame_name>camera_d455_depth_optical_frame</frame_name>
          <depth_image_topic_name>/d455/depth/image_raw</depth_image_topic_name>
          <point_cloud_topic_name>/d455/depth/points</point_cloud_topic_name>
          <depth_image_camera_info_topic_name>/d455/depth/camera_info</depth_image_camera_info_topic_name>
          <point_cloud>1</point_cloud>
        </plugin>
      </sensor>

      <sensor name='d455_imu' type='imu'>
        <always_on>1</always_on>
        <update_rate>200</update_rate>
        <pose>-0.52457 0 0.42892 0 -0 0</pose>
        <plugin name='d455_imu_controller' filename='libgazebo_ros_imu_sensor.so'>
          <ros><namespace>/d455/imu</namespace></ros>
          <frame_name>camera_d455_imu_frame</frame_name>
          <topic_name>/d455/imu/data_raw</topic_name>
          <gaussian_noise>0.0005</gaussian_noise>
        </plugin>
      </sensor>

      <!-- base_footprint_fixed_joint_lump__d435i_collision_collision_1 -->
      <!--base_footprint_fixed_joint_lump__d435i_visual_visual_1 -->
      <collision name='d435i_collision_1'>
        <pose>0.04512 0 1.77259 0 1.0472 0</pose>
        <geometry>
          <box>
            <size>0.09 0.025 0.025</size>
          </box>
        </geometry>
      </collision>

      <visual name='d435i_visual_1'>
        <pose>0.04512 0 1.77259 0 1.0472 0</pose>
        <geometry>
          <mesh>
            <scale>0.001 0.001 0.001</scale>
            <uri>model://uvc1_common/meshes/sensors/camera_d435i.dae</uri>
