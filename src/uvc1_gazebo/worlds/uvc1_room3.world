        <visual name="tray_vis"><pose>0 0 0.85 0 0 0</pose><geometry><box><size>0.50 0.40 0.04</size></box></geometry><material><ambient>0.80 0.80 0.85 1</ambient><diffuse>0.80 0.80 0.85 1</diffuse><specular>0.50 0.50 0.55 1</specular></material></visual>
