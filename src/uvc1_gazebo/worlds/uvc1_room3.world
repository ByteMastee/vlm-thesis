    <!-- MEDICAL MONITOR STAND (beside OT table, x=-7.8 y=1.5) -->
    <model name="medical_monitor">
      <static>1</static>
      <pose>-7.8 1.5 0 0 0 0</pose>
      <link name="link">
        <!-- Stand pole -->
        <visual name="pole_vis"><pose>0 0 0.75 0 0 0</pose><geometry><cylinder><radius>0.03</radius><length>1.50</length></cylinder></geometry><material><ambient>0.50 0.50 0.50 1</ambient><diffuse>0.50 0.50 0.50 1</diffuse></material></visual>
        <collision name="pole_col"><pose>0 0 0.75 0 0 0</pose><geometry><cylinder><radius>0.03</radius><length>1.50</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
        <!-- Base -->
        <visual name="base_vis"><pose>0 0 0.04 0 0 0</pose><geometry><cylinder><radius>0.22</radius><length>0.08</length></cylinder></geometry><material><ambient>0.40 0.40 0.40 1</ambient><diffuse>0.40 0.40 0.40 1</diffuse></material></visual>
