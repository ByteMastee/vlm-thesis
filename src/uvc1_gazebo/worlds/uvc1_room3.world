        <collision name="base_col"><pose>0 0 0.04 0 0 0</pose><geometry><cylinder><radius>0.20</radius><length>0.04</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
        <self_collide>0</self_collide><enable_wind>0</enable_wind><kinematic>0</kinematic>
