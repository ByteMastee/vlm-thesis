        <self_collide>0</self_collide><enable_wind>0</enable_wind><kinematic>0</kinematic>
      </link>
    </model>

    <!-- MEDICAL INSTRUMENT TROLLEY (beside OT table, x=-5.5 y=-0.5) -->
    <model name="instrument_trolley">
      <static>1</static>
      <pose>-5.5 -0.5 0 0 0 0</pose>
