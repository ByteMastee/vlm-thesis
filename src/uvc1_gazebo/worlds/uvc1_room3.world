        <visual name="leg2_vis"><pose>0.23 -0.18 0.425 0 0 0</pose><geometry><cylinder><radius>0.015</radius><length>0.85</length></cylinder></geometry><material><ambient>0.60 0.60 0.60 1</ambient><diffuse>0.60 0.60 0.60 1</diffuse></material></visual>
        <collision name="leg2_col"><pose>0.23 -0.18 0.425 0 0 0</pose><geometry><cylinder><radius>0.015</radius><length>0.85</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
        <visual name="leg3_vis"><pose>-0.23 0.18 0.425 0 0 0</pose><geometry><cylinder><radius>0.015</radius><length>0.85</length></cylinder></geometry><material><ambient>0.60 0.60 0.60 1</ambient><diffuse>0.60 0.60 0.60 1</diffuse></material></visual>
        <collision name="leg3_col"><pose>-0.23 0.18 0.425 0 0 0</pose><geometry><cylinder><radius>0.015</radius><length>0.85</length></cylinder></geometry><max_contacts>10</max_contacts></collision>
        <visual name="leg4_vis"><pose>0.23 0.18 0.425 0 0 0</pose><geometry><cylinder><radius>0.015</radius><length>0.85</length></cylinder></geometry><material><ambient>0.60 0.60 0.60 1</ambient><diffuse>0.60 0.60 0.60 1</diffuse></material></visual>
