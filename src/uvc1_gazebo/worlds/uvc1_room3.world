        <visual name="pole_vis"><pose>0 0 1.50 0 0 0</pose><geometry><cylinder><radius>0.04</radius><length>1.00</length></cylinder></geometry><material><ambient>0.70 0.70 0.70 1</ambient><diffuse>0.70 0.70 0.70 1</diffuse><specular>0.40 0.40 0.40 1</specular></material></visual>
