    <!-- Plate - center -->
    <model name="plate_2">
      <static>1</static>
      <pose>3.5 3.0 0.79 0 0 0</pose>
      <link name="link">
        <visual name="vis"><pose>0 0 0 0 0 0</pose><geometry><cylinder><radius>0.16</radius><length>0.02</length></cylinder></geometry><material><ambient>0.92 0.90 0.85 1</ambient><diffuse>0.92 0.90 0.85 1</diffuse><specular>0.30 0.30 0.28 1</specular></material></visual>
