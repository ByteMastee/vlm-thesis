        <visual name="top_vis"><pose>0 0 0.75 0 0 0</pose><geometry><box><size>1.60 0.90 0.06</size></box></geometry><material><ambient>0.50 0.28 0.10 1</ambient><diffuse>0.50 0.28 0.10 1</diffuse><specular>0.18 0.12 0.05 1</specular></material></visual>
