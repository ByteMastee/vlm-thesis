<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="virofighter_t265">

  <!-- Macro to instantiate all T265 fisheye cameras -->
  <xacro:macro name="t265_fisheye_cameras" params="parent material='Grey'">

    <!-- Front Fisheye -->
    <xacro:t265_fisheye_camera name="link_fisheye_front" parent="${parent}"
        xyz="0.07 0 1.845" rpy="0 0.628 -0.0255"
        material="${material}"/>

    <!-- Left Fisheye -->
    <xacro:t265_fisheye_camera name="link_fisheye_left" parent="${parent}"
        xyz="-0.2 0.18 1.845" rpy="0 0.628 1.5708"
        material="${material}"/>

    <!-- Right Fisheye -->
    <xacro:t265_fisheye_camera name="link_fisheye_right" parent="${parent}"
        xyz="-0.2 -0.18 1.845" rpy="0 0.628 -1.5708"
        material="${material}"/>

    <!-- Rear Fisheye -->
    <xacro:t265_fisheye_camera name="link_fisheye_rear" parent="${parent}"
        xyz="-0.5 0 1.845" rpy="3.1416 2.513274 0"
        material="${material}"/>

  </xacro:macro>

  <!-- Macro for a single T265 fisheye camera (like sonar style) -->
  <xacro:macro name="t265_fisheye_camera" params="name parent xyz rpy material='Red'">

    <link name="${name}">
      <collision name="${name}_collision">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.05"/>
        </geometry>
      </collision>
      <visual name="${name}_visual">
        <origin xyz="0 0 0" rpy="0 1.5708 0"/>
        <geometry>
          <cylinder radius="0.012" length="0.024"/>
        </geometry>
        <material name="${material}"/>
      </visual>
    </link>

    <joint name="joint_${name}" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

  </xacro:macro>

</robot>
