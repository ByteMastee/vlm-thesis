<!-- Bemásolni minden axis alá: <dynamics damping="0.005" friction="0.005" /> -->

    <!-- D435 RGB-D Camera -->
    <gazebo reference="link_d435_camera">
      <sensor name="d435_rgbd_camera" type="depth">
        <update_rate>30</update_rate>

        <camera>
          <horizontal_fov>1.0472</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>5.0</far>
          </clip>
        </camera>

        <plugin name="d435_rgbd_controller" filename="libgazebo_ros_camera.so">
          <!-- ROS2 namespace -->
          <ros>
            <namespace>/d435_rgbd_camera</namespace>
          </ros>

          <!-- TF frame -->
          <frame_name>link_d435_camera</frame_name>

          <alwaysOn>true</alwaysOn>
          <updateRate>30</updateRate>

          <!-- Camera names & topics -->
          <cameraName>d435_rgbd_camera</cameraName>
          <imageTopicName>/d435_rgbd_camera/color/image_raw</imageTopicName>
          <cameraInfoTopicName>/d435_rgbd_camera/color/camera_info</cameraInfoTopicName>
          <depthImageTopicName>/d435_rgbd_camera/depth/image_raw</depthImageTopicName>
          <depthCameraInfoTopicName>/d435_rgbd_camera/depth/camera_info</depthCameraInfoTopicName>
          <pointCloudTopicName>/d435_rgbd_camera/depth/points</pointCloudTopicName>

          <!-- Stereo baseline hack -->
          <baseline>0.05</baseline>
          <pointCloudCutoff>0.2</pointCloudCutoff>
          <pointCloudCutoffMax>5.0</pointCloudCutoffMax>
        </plugin>
      </sensor>
    </gazebo>

    <!-- Front Fisheye -->
    <gazebo reference="link_fisheye_front">
      <sensor name="fisheye_front_camera" type="wideanglecamera">
        <camera>
          <horizontal_fov>6.283</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
          <lens>
            <type>custom</type>
            <custom_function>
              <c1>1.0</c1>
              <c2>4.0</c2>
              <f>1.0</f>
              <fun>tan</fun>
            </custom_function>
            <scale_to_hfov>true</scale_to_hfov>
            <cutoff_angle>3.1415</cutoff_angle>
            <env_texture_size>512</env_texture_size>
          </lens>
          <always_on>true</always_on>
          <update_rate>30</update_rate>
        </camera>
        <plugin name="fisheye_front_controller" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>/fisheye_front</namespace>
          </ros>
          <frame_name>fisheye_front_link</frame_name>
          <alwaysOn>true</alwaysOn>
          <updateRate>30</updateRate>
          <cameraName>fisheye_front_camera</cameraName>
          <imageTopicName>/fisheye_front/image_raw</imageTopicName>
          <cameraInfoTopicName>/fisheye_front/camera_info</cameraInfoTopicName>
          <distortionK1>-0.05268338601520044</distortionK1>
          <distortionK2>0.004889702830369265</distortionK2>
          <distortionK3>-0.0031745403716575385</distortionK3>
