    <!-- Realsense t265 stereo fisheye camera -->
    <gazebo reference="link_t265_camera_fisheye">
      <sensor name="t265_fisheye_camera" type="wideanglecamera">
        <camera>
          <horizontal_fov>6.283</horizontal_fov>
          <image>
            <width>800</width>
            <height>848</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
          <lens>
            <type>custom</type>
            <custom_function>
              <c1>1.05</c1>
              <c2>4</c2>
              <f>1.0</f>
              <fun>tan</fun>
            </custom_function>
            <scale_to_hfov>true</scale_to_hfov>
            <cutoff_angle>3.1415</cutoff_angle>
            <env_texture_size>512</env_texture_size>
          </lens>
          <always_on>true</always_on>
          <update_rate>30</update_rate>
        </camera>

        <plugin name="t265_fisheye_controller" filename="libgazebo_ros_camera.so">
          <!-- ROS2-style namespace -->
          <ros>
            <namespace>/t265_fisheye_camera</namespace>
          </ros>

          <!-- TF frame -->
          <frame_name>t265_link</frame_name>

          <alwaysOn>true</alwaysOn>
          <updateRate>30</updateRate>

          <!-- Camera names & topics -->
          <cameraName>t265_fisheye_camera</cameraName>
          <imageTopicName>/t265_fisheye_camera/image_raw</imageTopicName>
          <cameraInfoTopicName>/t265_fisheye_camera/camera_info</cameraInfoTopicName>

          <!-- Stereo baseline hack (if needed) -->
          <hackBaseline>0.07</hackBaseline>

          <!-- Calibration / distortion parameters -->
          <distortionK1>-0.007419134024530649</distortionK1>
          <distortionK2>0.041209351271390915</distortionK2>
          <distortionK3>-0.03811917081475258</distortionK3>
          <distortionT1>0.006366158835589886</distortionT1>
          <distortionT2>0.0</distortionT2>
          <CxPrime>416.00531005859375</CxPrime>
          <Cx>16.00531005859375</Cx>
          <Cy>403.38909912109375</Cy>
        </plugin>
      </sensor>
    </gazebo>

    <!-- Realsense T265 IMU / gyro -->
    <gazebo reference="link_t265_camera_gyro">
      <gravity>true</gravity>
      <sensor name="t265_camera_imu" type="imu">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <plugin filename="libgazebo_ros_imu_sensor.so" name="t265_imu_plugin">
          <topicName>/t265/gyro/sample</topicName>
          <bodyName>link_t265_camera_gyro</bodyName>
          <updateRateHZ>30</updateRateHZ>
          <gaussianNoise>0.000001</gaussianNoise>
          <xyzOffset>0 0 0</xyzOffset>
          <rpyOffset>0 0 0</rpyOffset>
          <frameName>t265_link</frameName>
        </plugin>
      </sensor>
    </gazebo>

    <!-- Realsense T265 odometry -->
    <gazebo reference="link_t265_camera_odom">
      <plugin name="t265_odom_plugin" filename="libgazebo_ros_p3d.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>30</updateRate>
        <bodyName>link_t265_camera_odom</bodyName>
        <topicName>/t265/odom/sample</topicName>
        <gaussianNoise>0.001</gaussianNoise>
        <frameName>odom</frameName>
        <xyzOffsets>0 0 0</xyzOffsets>
        <rpyOffsets>0 0 0</rpyOffsets>
      </plugin>
    </gazebo>


    <!-- Ultrasonic rear-->
    <gazebo reference="link_rear_sonar">
      <sensor type="ray" name="sonar">
        <pose>0 0 0 0 0 0</pose>
        <visualize>true</visualize>
        <update_rate>5</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>5</samples>
              <resolution>1.0</resolution>
              <min_angle>-0.25</min_angle>
              <max_angle>0.25</max_angle>
            </horizontal>
            <vertical>
              <samples>5</samples>
              <resolution>1</resolution>
              <min_angle>-0.25</min_angle>
              <max_angle>0.25</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.01</min>
            <max>0.75</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
        <plugin filename="libgazebo_ros_range.so" name="gazebo_ros_range">
          <gaussianNoise>0.005</gaussianNoise>
          <alwaysOn>true</alwaysOn>
          <updateRate>5</updateRate>
          <topicName>/ultrasound/rear</topicName>
          <frameName>rear</frameName>
          <fov>0.5</fov>
          <radiation>ultrasound</radiation>
        </plugin>
      </sensor>
    </gazebo>
    
