    <!-- Main Body -->
    <link name="link_virofighter">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="10.011"/>
        <inertia ixx="13.2077" ixy="0" ixz="0" iyy="13.3744" iyz="0" izz="0.34275"/>
      </inertial>
