<?xml version="1.0"?>
<!-- created with Phobos 1.0.1 "Capricious Choutengan" -->
  <robot name="robot">

    <!-- Dummy root link (KDL-safe, massless) -->
    <link name="base_link"/>

    <!-- Fixed joint to real robot body -->
    <joint name="base_link_to_virofighter" type="fixed">
      <parent link="base_link"/>
      <child link="link_virofighter"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Front Wheels -->
    <link name="link_front_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="7.90271"/>
        <inertia ixx="0.01506" ixy="0" ixz="0" iyy="0.01506" iyz="0" izz="0.02704"/>
      </inertial>
      <visual name="front_left_wheel">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="model://UVC_robot_new/meshes/dae/front_left_wheel.dae" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <collision name="front_left_wheel">
        <origin xyz="0 0.00277 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="0.08273" length="0.04836"/>
        </geometry>
      </collision>
    </link>

    <joint name="joint_front_left_wheel" type="continuous">
      <origin xyz="0 -0.17827 0.082" rpy="0 0 0"/>
      <parent link="link_virofighter"/>
      <child link="link_front_left_wheel"/>
      <axis xyz="0 1.0 0"/>
      <dynamics damping="0.005" friction="0.005" />
    </joint>

    <link name="link_front_right_wheel">
