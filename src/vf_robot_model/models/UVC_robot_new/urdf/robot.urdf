          <distortionT2>0.0</distortionT2>
          <CxPrime>271.7130252551282</CxPrime>
          <Cx>320.79340187886527</Cx>
          <Cy>226.64923232430766</Cy>
        </plugin>
      </sensor>
    </gazebo>

    <!-- Left Fisheye -->
    <gazebo reference="link_fisheye_left">
      <sensor name="fisheye_left_camera" type="wideanglecamera">
        <camera>
          <horizontal_fov>6.283</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
          <lens>
